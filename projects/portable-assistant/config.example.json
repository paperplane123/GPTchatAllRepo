{
  "default_profile": "balanced",
  "identity_file": "identity/core.md",
  "memory_path": "data/memory.jsonl",
  "skills_path": "skills",
  "profiles": {
    "balanced": {
      "timeout_seconds": 90,
      "max_attempts_per_provider": 1,
      "providers": [
        {
          "name": "openai",
          "type": "openai",
          "model": "${OPENAI_MODEL}",
          "api_key_env": "OPENAI_API_KEY",
          "base_url": "https://api.openai.com/v1",
          "priority": 10,
          "max_tokens": 4096,
          "enabled": true
        },
        {
          "name": "anthropic",
          "type": "anthropic",
          "model": "${ANTHROPIC_MODEL}",
          "api_key_env": "ANTHROPIC_API_KEY",
          "base_url": "https://api.anthropic.com",
          "priority": 20,
          "max_tokens": 4096,
          "enabled": true
        },
        {
          "name": "gemini",
          "type": "gemini",
          "model": "${GEMINI_MODEL}",
          "api_key_env": "GEMINI_API_KEY",
          "base_url": "https://generativelanguage.googleapis.com/v1beta",
          "priority": 30,
          "max_tokens": 4096,
          "enabled": true
        }
      ]
    }
  }
}
